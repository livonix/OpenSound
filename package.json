{
  "name": "opensound",
  "version": "1.0.1",
  "description": "Desktop music streaming app with Spotify metadata and YouTube audio",
  "main": "dist/main/index.js",
  "homepage": "./",
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "cd src/renderer && npm run dev",
    "dev:main": "tsc -p tsconfig.main.json && tsc -p src/main/preload-tsconfig.json && node -e \"setTimeout(() => console.log('Starting Electron...'), 5000)\" && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "cd src/renderer && npm run build",
    "build:main": "tsc -p tsconfig.shared.json && tsc -p tsconfig.main.json && tsc -p src/main/preload-tsconfig.json",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "postinstall": "cd src/renderer && npm install",
    "version:patch": "node scripts/version.js patch",
    "version:minor": "node scripts/version.js minor",
    "version:major": "node scripts/version.js major",
    "release": "npm run build && npm run dist",
    "release:patch": "npm run version:patch && npm run release",
    "release:minor": "npm run version:minor && npm run release",
    "release:major": "npm run version:major && npm run release"
  },
  "keywords": [
    "music",
    "streaming",
    "electron",
    "spotify",
    "youtube"
  ],
  "author": "OpenSound Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.0",
    "typescript": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^17.3.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "fluent-ffmpeg": "^2.1.3",
    "uuid": "^9.0.0",
    "ytdl-core": "^4.11.1"
  },
  "build": {
    "appId": "com.opensound.app",
    "productName": "OpenSound",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "livonix",
      "repo": "OpenSound"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OpenSound",
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "menuCategory": "OpenSound",
      "license": "LICENSE.txt"
    },
    "mac": {
      "category": "public.app-category.music"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}