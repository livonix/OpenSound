{
  "name": "opensound",
  "version": "1.0.0",
  "description": "Desktop music streaming app with Spotify metadata and YouTube audio",
  "main": "dist/main/index.js",
  "homepage": "./",
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "cd src/renderer && npm run dev",
    "dev:main": "tsc -p tsconfig.main.json && tsc -p src/main/preload-tsconfig.json && node -e \"setTimeout(() => console.log('Starting Electron...'), 5000)\" && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "cd src/renderer && npm run build",
    "build:main": "tsc -p tsconfig.shared.json && tsc -p tsconfig.main.json && tsc -p src/main/preload-tsconfig.json",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "postinstall": "cd src/renderer && npm install"
  },
  "keywords": [
    "music",
    "streaming",
    "electron",
    "spotify",
    "youtube"
  ],
  "author": "OpenSound Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.0",
    "typescript": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^17.3.1",
    "fluent-ffmpeg": "^2.1.3",
    "sqlite3": "^5.1.0",
    "uuid": "^9.0.0",
    "ytdl-core": "^4.11.1"
  },
  "build": {
    "appId": "com.opensound.app",
    "productName": "OpenSound",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.music"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
