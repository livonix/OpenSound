{
  "compilerOptions": {
    "target": "ES2020",
    "module": "es2020",
    "lib": ["ES2020"],
    "moduleResolution": "bundler",
    "outDir": "dist/main/shared",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "composite": true
  },
  "include": [
    "src/shared/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist/**/*"
  ]
}
